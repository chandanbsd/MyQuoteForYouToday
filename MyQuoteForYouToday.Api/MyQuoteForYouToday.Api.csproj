    </ItemGroup>

    <ItemGroup>
      <Content Include="..\.dockerignore">
        <Link>.dockerignore</Link>
      </Content>
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\MyQuoteForYouToday.Business\MyQuoteForYouToday.Business.csproj" />
      <ProjectReference Include="..\MyQuoteForYouToday.ServiceDefaults\MyQuoteForYouToday.ServiceDefaults.csproj" />
    </ItemGroup>

</Project>
